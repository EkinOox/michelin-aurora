# ── Environnement & secrets ───────────────────────────────────────────────────
# Racine (docker-compose) : .env contient les vrais secrets, jamais commité.
/.env
.env.*.local
# Secrets de prod côté serveur (jamais commités) ; seul .env.prod.example l'est.
/deploy/.env.prod
*.pem
*.key
*.p12
*.pfx

# ── Symfony (apps/back) ────────────────────────────────────────────────────────
# Convention Symfony : apps/back/.env est commité (valeurs par défaut, sans
# secret de prod) ; apps/back/.env.local contient les overrides locaux/secrets.
apps/back/.env.local
apps/back/var/
apps/back/vendor/
apps/back/public/bundles/
apps/back/.php-cs-fixer.cache
apps/back/.phpunit.result.cache

# ── Nuxt 3 (apps/front) ──────────────────────────────────────────────────────
apps/front/.nuxt/
apps/front/.output/
apps/front/node_modules/
apps/front/dist/
apps/front/.cache/

# ── Python (simulator) ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Système ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
